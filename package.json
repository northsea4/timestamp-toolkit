{
  "name": "timestamp-toolkit",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "vite build --watch",
    "dev:server": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "format": "oxfmt src/ vite.config.ts tsconfig.json package.json .oxfmtrc.json .oxlintrc.json",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.31",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  }
}
